{{!
    @template mod_attendancecontrol/attendance_table

    Attendance registration form for a single session.

    Example context (json):
    {
        "action_url": "/mod/attendancecontrol/attendance.php?id=1&sessionid=1",
        "sesskey": "abc123",
        "id": 1,
        "sessionid": 1,
        "cancel_url": "/mod/attendancecontrol/view.php?id=1",
        "str_save": "Save attendance",
        "str_cancel": "Cancel",
        "str_markall": "Mark all",
        "students": [
            {
                "uid": 2,
                "fullname": "Jane Doe",
                "remarks": "",
                "statuses": [
                    {"uid": 2, "value": 1, "label": "Present", "btn_class": "btn-outline-success", "checked": true, "input_id": "status_2_1"},
                    {"uid": 2, "value": 2, "label": "Late", "btn_class": "btn-outline-warning", "checked": false, "input_id": "status_2_2"},
                    {"uid": 2, "value": 3, "label": "Justified absence", "btn_class": "btn-outline-info", "checked": false, "input_id": "status_2_3"},
                    {"uid": 2, "value": 4, "label": "Unjustified absence", "btn_class": "btn-outline-danger", "checked": false, "input_id": "status_2_4"}
                ]
            }
        ]
    }

    @copyright  2026 David Oliván Malagón
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<form method="post" action="{{action_url}}" data-region="attendance-form">
    <input type="hidden" name="sesskey"   value="{{sesskey}}">
    <input type="hidden" name="id"        value="{{id}}">
    <input type="hidden" name="sessionid" value="{{sessionid}}">

    {{! Student attendance table }}
    <div class="table-responsive">
        <table class="table table-sm table-hover table-bordered generaltable align-middle">
            <thead class="table-light">
                <tr>
                    <th scope="col">{{#str}}studentname, mod_attendancecontrol{{/str}}</th>
                    <th scope="col" class="text-center text-success">
                        {{#str}}statuspresent, mod_attendancecontrol{{/str}}
                        <div class="mt-1">
                            <button type="button"
                                    class="btn btn-outline-success btn-sm"
                                    data-action="mark-all"
                                    data-status="1">{{str_markall}}</button>
                        </div>
                    </th>
                    <th scope="col" class="text-center text-warning">
                        {{#str}}statuslate, mod_attendancecontrol{{/str}}
                        <div class="mt-1">
                            <button type="button"
                                    class="btn btn-outline-warning btn-sm"
                                    data-action="mark-all"
                                    data-status="2">{{str_markall}}</button>
                        </div>
                    </th>
                    <th scope="col" class="text-center text-info">
                        {{#str}}statusjustified, mod_attendancecontrol{{/str}}
                        <div class="mt-1">
                            <button type="button"
                                    class="btn btn-outline-info btn-sm"
                                    data-action="mark-all"
                                    data-status="3">{{str_markall}}</button>
                        </div>
                    </th>
                    <th scope="col" class="text-center text-danger">
                        {{#str}}statusunjustified, mod_attendancecontrol{{/str}}
                        <div class="mt-1">
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    data-action="mark-all"
                                    data-status="4">{{str_markall}}</button>
                        </div>
                    </th>
                    <th scope="col">{{#str}}remarks, mod_attendancecontrol{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#students}}
                <tr>
                    <td class="fw-semibold">{{fullname}}</td>
                    {{#statuses}}
                    <td class="text-center p-1">
                        <input class="btn-check"
                               type="radio"
                               name="student_status[{{uid}}]"
                               id="{{input_id}}"
                               value="{{value}}"
                               autocomplete="off"
                               {{#checked}}checked{{/checked}}>
                        <label class="btn {{btn_class}} btn-sm py-1 px-2" for="{{input_id}}"
                               title="{{label}}">✓</label>
                    </td>
                    {{/statuses}}
                    <td class="p-1">
                        <input type="text"
                               class="form-control form-control-sm"
                               name="student_remarks[{{uid}}]"
                               value="{{remarks}}"
                               style="min-width: 130px;">
                    </td>
                </tr>
                {{/students}}
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">{{str_save}}</button>
        <a href="{{cancel_url}}" class="btn btn-secondary">{{str_cancel}}</a>
    </div>
</form>
